{
  "name": "ai-mines-js",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "build": "tsc --build",
    "dev": "pnpm --filter @ai-mines/web-three dev",
    "tauri:dev": "pnpm --filter @ai-mines/web-three tauri:dev",
    "tauri:build": "pnpm --filter @ai-mines/web-three tauri:build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
